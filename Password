a = input("enter the password")
up = 0
sm = 0
dg = 0
sp = 0
if len(a) > 7:
    for i in a:
        if i.isupper():
            up += 1
        elif i.islower():
            sm += 1
        elif i.isdigit():
            dg += 1
        else:
            sp += 1
    if up != 0 and sm != 0 and dg != 0 and sp != 0:
        print("strong")
    else:
        print("weak")
else:
    print("len of pass is small")
 
